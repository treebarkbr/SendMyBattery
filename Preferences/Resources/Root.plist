{
	title = SendMyBattery;
	items = (
		{
			cell = PSGroupCell;
			label = "UDP Sender";
			footerText = "Sends a compact UDP packet when the battery percentage changes. No polling or heartbeat is used.";
		},
		{
			cell = PSSwitchCell;
			default = 1;
			defaults = "com.treebarkbr.sendmybattery";
			key = enabled;
			label = Enabled;
			PostNotification = "com.treebarkbr.sendmybattery/preferences.changed";
		},
		{
			cell = PSEditTextCell;
			defaults = "com.treebarkbr.sendmybattery";
			key = host;
			label = Host;
			placeholder = "192.168.1.10";
			PostNotification = "com.treebarkbr.sendmybattery/preferences.changed";
		},
		{
			cell = PSEditTextCell;
			defaults = "com.treebarkbr.sendmybattery";
			key = port;
			keyboard = numberPad;
			label = Port;
			placeholder = 9999;
			PostNotification = "com.treebarkbr.sendmybattery/preferences.changed";
		},
		{
			cell = PSSwitchCell;
			default = 1;
			defaults = "com.treebarkbr.sendmybattery";
			key = sendInitial;
			label = "Send Initial Packet";
			PostNotification = "com.treebarkbr.sendmybattery/preferences.changed";
		},
		{
			cell = PSGroupCell;
			footerText = "Payload format: {\"battery\":87}";
		}
	);
}
